POSTGRES_DB=sewing_shop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# For `python manage.py` on your laptop (Postgres from Docker mapped to localhost:5432):
POSTGRES_HOST=localhost
# Note: `docker-compose.yml` sets POSTGRES_HOST=db inside the `web` container — you keep localhost here.
POSTGRES_PORT=5432
DEBUG=1
SECRET_KEY=change-me-for-production
